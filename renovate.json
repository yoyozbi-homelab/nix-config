{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "semanticCommits": "enabled",
  "ignorePaths": [
    "node_modules/**",
    ".venv/**",
    "venv/**",
    "**/flake.lock"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Rancher HelmChart versions (Helm repository)",
      "managerFilePatterns": [
        "nixos/roles/k3s/manifests/*.yaml"
      ],
      "matchStrings": [
        "kind: HelmChart[\\s\\S]{0,500}repo: (?<registryUrl>https?://[^\\n]+)[\\s\\S]{0,500}chart: (?<depName>[^\\n]+)[\\s\\S]{0,500}version: (?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "helm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update Rancher HelmChart versions (OCI charts)",
      "managerFilePatterns": [
        "nixos/roles/k3s/manifests/*.yaml"
      ],
      "matchStrings": [
        "kind: HelmChart[\\s\\S]{0,500}chart: oci://(?<depName>[^\\n]+)[\\s\\S]{0,500}version: (?<currentValue>[^\\n]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "Update Docker images in K3s manifests",
      "managerFilePatterns": [
        "nixos/roles/k3s/manifests/*.yaml"
      ],
      "matchStrings": [
        "image: (?<depName>[^:\\s]+):(?<currentValue>[^\\s#]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Update Docker images in arion stacks",
      "managerFilePatterns": [
        "nixos/roles/docker/**/*.nix"
      ],
      "matchStrings": [
        "image\\s*=\\s*\"(?<depName>[^:\"\\s]+):(?<currentValue>[^\"\\s#]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "cloudflare/cloudflared"
      ],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d+)\\.(?<patch>\\d+)$"
    },
    {
      "description": "Group Kubernetes and Helm Chart updates together",
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "Kubernetes and Helm Charts",
      "commitMessagePrefix": "chore(k8s): "
    },
    {
      "description": "Group arion Docker image updates (override the custom.regex k8s group)",
      "matchFileNames": [
        "nixos/roles/docker/**"
      ],
      "groupName": "arion Docker images",
      "commitMessagePrefix": "chore(docker): "
    },
    {
      "description": "GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "commitMessagePrefix": "ci(actions): "
    },
    {
      "description": "Automatically rebase non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "rebaseWhen": "behind-base-branch"
    }
  ]
}
